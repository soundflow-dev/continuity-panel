#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LABEL="dev.continuitypanel.mission-control"
DOMAIN="gui/$(id -u)"
USER_RECORD="/${CONTINUITYPANEL_USER_RECORD_KIND:-Users}/$(id -un)"
MACOS_USER_HOME="$(/usr/bin/dscl . -read "$USER_RECORD" NFSHomeDirectory | /usr/bin/sed -E 's/^[^:]+:[[:space:]]*//')"
PLIST="$MACOS_USER_HOME/Library/LaunchAgents/$LABEL.plist"
source "$ROOT/bin/agentic-env"

mkdir -p "$MISSION_CONTROL_DATA_DIR"
if [[ ! -f "$PLIST" ]]; then
  "$ROOT/bin/install-service"
fi

if launchctl print "$DOMAIN/$LABEL" >/dev/null 2>&1; then
  launchctl kickstart -k "$DOMAIN/$LABEL"
else
  launchctl bootstrap "$DOMAIN" "$PLIST"
fi

for _ in {1..30}; do
  if curl -fsS "$MC_URL/api/status" >/dev/null 2>&1 || curl -fsS "$MC_URL/login" >/dev/null 2>&1; then
    echo "Mission Control started at $MC_URL"
    exit 0
  fi
  sleep 1
done

echo "Mission Control did not become ready. See $MISSION_CONTROL_DATA_DIR/mc-error.log" >&2
exit 1
