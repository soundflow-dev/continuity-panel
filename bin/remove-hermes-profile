#!/usr/bin/env bash
set -euo pipefail

ROOT="${CONTINUITYPANEL_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
TRASH_DIR="${CONTINUITYPANEL_TRASH_DIR:-$HOME/.Trash}"
PROFILE_ID="${1:-}"
DEFAULT_HOME="$ROOT/home/.hermes"
PROFILE_DIR="$DEFAULT_HOME/profiles/$PROFILE_ID"
DB="$ROOT/mission-control/.data/mission-control.db"

if [[ "$PROFILE_ID" != "__default__" ]] && [[ ! "$PROFILE_ID" =~ ^[a-z0-9][a-z0-9_-]*$ ]]; then
  echo "Usage: $0 profile-id" >&2
  exit 2
fi
if [[ "$PROFILE_ID" == "__default__" ]]; then
  if [[ ! -f "$DEFAULT_HOME/config.yaml" ]] && [[ ! -f "$DEFAULT_HOME/.continuitypanel-profile.json" ]]; then
    echo "The default Hermes profile is not configured." >&2
    exit 1
  fi
elif [[ ! -d "$PROFILE_DIR" ]]; then
  echo "Hermes profile does not exist: $PROFILE_ID" >&2
  exit 1
fi

sql_escape() {
  printf '%s' "$1" | sed "s/'/''/g"
}
escaped_profile="$(sql_escape "$PROFILE_ID")"
agent_names=""

if [[ -f "$DB" ]] && [[ "$(sqlite3 "$DB" "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='agents';")" == "1" ]]; then
  if [[ "$PROFILE_ID" == "__default__" ]]; then
    agent_names="$(sqlite3 "$DB" "SELECT name FROM agents WHERE workspace_id=1 AND (json_extract(config, '$.dispatchRuntime')='hermes' OR runtime_type='hermes') AND coalesce(json_extract(config, '$.hermesProfile'), '')='';")"
  else
    agent_names="$(sqlite3 "$DB" "SELECT name FROM agents WHERE workspace_id=1 AND json_extract(config, '$.hermesProfile')='$escaped_profile';")"
  fi
  while IFS= read -r agent_name; do
    [[ -z "$agent_name" ]] && continue
    escaped_agent="$(sql_escape "$agent_name")"
    active_tasks="$(sqlite3 "$DB" "SELECT count(*) FROM tasks WHERE workspace_id=1 AND assigned_to='$escaped_agent' AND status IN ('assigned','in_progress');" 2>/dev/null || printf '0')"
    if [[ "$active_tasks" != "0" ]]; then
      echo "Finish or reassign the active tasks for $agent_name before removing this profile." >&2
      exit 1
    fi
  done <<< "$agent_names"
fi

mkdir -p "$TRASH_DIR"
trash_name="$PROFILE_ID"
[[ "$PROFILE_ID" == "__default__" ]] && trash_name="default"
destination="$TRASH_DIR/ContinuityPanel-Hermes-$trash_name"
if [[ -e "$destination" ]]; then
  destination="$TRASH_DIR/ContinuityPanel-Hermes-$trash_name-$(date +%Y%m%d-%H%M%S)"
fi

hide_agents() {
  local hidden="$1"
  local status="$2"
  [[ -z "$agent_names" ]] && return 0
  while IFS= read -r agent_name; do
    [[ -z "$agent_name" ]] && continue
    escaped_agent="$(sql_escape "$agent_name")"
    sqlite3 "$DB" "PRAGMA busy_timeout=5000; UPDATE agents SET hidden=$hidden, status='$status', updated_at=unixepoch() WHERE workspace_id=1 AND name='$escaped_agent';" >/dev/null
  done <<< "$agent_names"
}

hide_agents 1 offline

if [[ "$PROFILE_ID" == "__default__" ]]; then
  mkdir -p "$destination"
  shopt -s dotglob nullglob
  moved=()
  for item in "$DEFAULT_HOME"/*; do
    name="$(basename "$item")"
    case "$name" in
      hermes-agent|hooks|profiles) continue ;;
    esac
    if mv "$item" "$destination/"; then
      moved+=("$name")
    else
      for moved_name in "${moved[@]}"; do
        mv "$destination/$moved_name" "$DEFAULT_HOME/" 2>/dev/null || true
      done
      rmdir "$destination" 2>/dev/null || true
      hide_agents 0 idle
      echo "Could not move the default Hermes profile to Trash." >&2
      exit 1
    fi
  done
  if [[ ${#moved[@]} -eq 0 ]]; then
    rmdir "$destination" 2>/dev/null || true
    hide_agents 0 idle
    echo "The default Hermes profile has no removable data." >&2
    exit 1
  fi
elif ! mv "$PROFILE_DIR" "$destination"; then
  hide_agents 0 idle
  echo "Could not move the Hermes profile to Trash." >&2
  exit 1
fi

echo "Moved Hermes profile $PROFILE_ID to Trash. Hermes remains installed and shared provider credentials were kept."
