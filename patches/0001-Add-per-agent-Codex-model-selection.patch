+import { describe, expect, it } from 'vitest'
+import { parseCodexModelCatalog } from '@/lib/codex-models'
+
+describe('parseCodexModelCatalog', () => {
+  it('returns compact model data and reasoning efforts from the Codex catalog', () => {
+    const models = parseCodexModelCatalog(JSON.stringify({
+      models: [{
+        slug: 'gpt-5.6-sol',
+        display_name: 'GPT-5.6-Sol',
+        description: 'Frontier model',
+        visibility: 'list',
+        default_reasoning_level: 'medium',
+        supported_reasoning_levels: [{ effort: 'low' }, { effort: 'high' }],
+        base_instructions: 'large value that must not be exposed',
+      }],
+    }))
+
+    expect(models).toEqual([{
+      slug: 'gpt-5.6-sol',
+      displayName: 'GPT-5.6-Sol',
+      description: 'Frontier model',
+      defaultReasoningLevel: 'medium',
+      supportedReasoningLevels: ['low', 'high'],
+    }])
+  })
+
+  it('filters hidden and malformed entries', () => {
+    expect(parseCodexModelCatalog(JSON.stringify({
+      models: [
+        { slug: 'hidden', visibility: 'hide' },
+        { display_name: 'Missing slug' },
+      ],
+    }))).toEqual([])
+  })
+})
