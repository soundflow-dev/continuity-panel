@@ -0,0 +1,67 @@
+export interface CodexModelOption {
+  slug: string
+  displayName: string
+  description: string
+  defaultReasoningLevel: string
+  supportedReasoningLevels: string[]
+}
+
+export const CODEX_MODEL_FALLBACKS: CodexModelOption[] = [
+  {
+    slug: 'gpt-5.6-sol',
+    displayName: 'GPT-5.6 Sol',
+    description: 'Latest frontier agentic coding model.',
+    defaultReasoningLevel: 'low',
+    supportedReasoningLevels: ['low', 'medium', 'high', 'xhigh', 'max', 'ultra'],
+  },
+  {
+    slug: 'gpt-5.6-terra',
+    displayName: 'GPT-5.6 Terra',
+    description: 'Balanced agentic coding model for everyday work.',
+    defaultReasoningLevel: 'medium',
+    supportedReasoningLevels: ['low', 'medium', 'high', 'xhigh', 'max', 'ultra'],
+  },
+  {
+    slug: 'gpt-5.6-luna',
+    displayName: 'GPT-5.6 Luna',
+    description: 'Fast coding model for clear and repeatable tasks.',
+    defaultReasoningLevel: 'medium',
+    supportedReasoningLevels: ['low', 'medium', 'high', 'xhigh', 'max'],
+  },
+]
+
+export function parseCodexModelCatalog(raw: string): CodexModelOption[] {
+  const payload = JSON.parse(raw) as { models?: unknown }
+  if (!Array.isArray(payload.models)) return []
+
+  return payload.models.flatMap((value): CodexModelOption[] => {
+    if (!value || typeof value !== 'object') return []
+    const model = value as Record<string, unknown>
+    const slug = typeof model.slug === 'string' ? model.slug.trim() : ''
+    if (!slug || model.visibility === 'hide') return []
+
+    const supportedReasoningLevels = Array.isArray(model.supported_reasoning_levels)
+      ? model.supported_reasoning_levels
+          .map((level) => {
+            if (typeof level === 'string') return level.trim()
+            if (level && typeof level === 'object' && typeof (level as Record<string, unknown>).effort === 'string') {
+              return ((level as Record<string, unknown>).effort as string).trim()
+            }
+            return ''
+          })
+          .filter(Boolean)
+      : []
+
+    return [{
+      slug,
+      displayName: typeof model.display_name === 'string' && model.display_name.trim()
+        ? model.display_name.trim()
+        : slug,
+      description: typeof model.description === 'string' ? model.description.trim() : '',
+      defaultReasoningLevel: typeof model.default_reasoning_level === 'string'
+        ? model.default_reasoning_level.trim()
+        : '',
+      supportedReasoningLevels: Array.from(new Set(supportedReasoningLevels)),
+    }]
+  })
+}
