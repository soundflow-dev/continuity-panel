+++ b/src/app/api/codex/models/route.ts
@@ -0,0 +1,22 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { requireRole } from '@/lib/auth'
+import { runCommand } from '@/lib/command'
+import { CODEX_MODEL_FALLBACKS, parseCodexModelCatalog } from '@/lib/codex-models'
+import { logger } from '@/lib/logger'
+
+export async function GET(request: NextRequest) {
+  const auth = requireRole(request, 'viewer')
+  if ('error' in auth) return NextResponse.json({ error: auth.error }, { status: auth.status })
+
+  try {
+    const { stdout } = await runCommand('codex', ['debug', 'models'], { timeoutMs: 15_000 })
+    const models = parseCodexModelCatalog(stdout)
+    return NextResponse.json({
+      models: models.length > 0 ? models : CODEX_MODEL_FALLBACKS,
+      source: models.length > 0 ? 'codex-cli' : 'fallback',
+    })
+  } catch (error) {
+    logger.warn({ err: error }, 'Unable to load Codex CLI model catalog')
+    return NextResponse.json({ models: CODEX_MODEL_FALLBACKS, source: 'fallback' })
+  }
+}
