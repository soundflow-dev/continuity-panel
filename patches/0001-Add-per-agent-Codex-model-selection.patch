+export function resolveCodexCliSettings(
+  task: Pick<DispatchableTask, 'agent_config'>
+): { model: string; reasoningEffort: string } {
+  if (!task.agent_config) return { model: '', reasoningEffort: '' }
+  try {
+    const cfg = JSON.parse(task.agent_config)
+    const model = typeof cfg.codexModel === 'string' && /^gpt-[a-z0-9.-]+$/i.test(cfg.codexModel.trim())
+      ? cfg.codexModel.trim()
+      : ''
+    const allowedEfforts = new Set(['low', 'medium', 'high', 'xhigh', 'max', 'ultra'])
+    const reasoningEffort = typeof cfg.codexReasoningEffort === 'string'
+      && allowedEfforts.has(cfg.codexReasoningEffort.trim().toLowerCase())
+      ? cfg.codexReasoningEffort.trim().toLowerCase()
+      : ''
+    return { model, reasoningEffort }
+  } catch {
+    return { model: '', reasoningEffort: '' }
+  }
+}
