diff --git a/src/lib/__tests__/task-retry-route.test.ts b/src/lib/__tests__/task-retry-route.test.ts
new file mode 100644
index 0000000..773cf53
--- /dev/null
+++ b/src/lib/__tests__/task-retry-route.test.ts
@@ -0,0 +1,84 @@
+import { beforeEach, describe, expect, it, vi } from 'vitest'
+import { NextRequest } from 'next/server'
+
+const requireRole = vi.fn()
+const prepare = vi.fn()
+const broadcast = vi.fn()
+const logActivity = vi.fn()
+
+vi.mock('@/lib/auth', () => ({ requireRole }))
+vi.mock('@/lib/rate-limit', () => ({ mutationLimiter: vi.fn(() => null) }))
+vi.mock('@/lib/enforcement/workspace-scope', () => ({
+  requireWorkspaceId: vi.fn((user) => ({ workspaceId: user.workspace_id })),
+  requireAgentTaskAccess: vi.fn(() => null),
+}))
+vi.mock('@/lib/event-bus', () => ({ eventBus: { broadcast } }))
+vi.mock('@/lib/logger', () => ({ logger: { error: vi.fn() } }))
+vi.mock('@/lib/db', () => ({
+  getDatabase: vi.fn(() => ({ prepare })),
+  db_helpers: { logActivity },
+}))
+
+describe('POST /api/tasks/[id]/retry', () => {
+  beforeEach(() => {
+    vi.resetModules()
+    vi.clearAllMocks()
+    requireRole.mockReturnValue({ user: { username: 'admin', role: 'admin', workspace_id: 1 } })
+  })
+
+  it('clears cancellation state and requeues with the current assignee', async () => {
+    const failedTask = {
+      id: 42,
+      title: 'Snake game',
+      status: 'failed',
+      assigned_to: 'Hermes Deepseek V4 pro',
+      metadata: JSON.stringify({
+        runtime_cancel_requested: true,
+        runtime_cancelled_at: 123,
+        dispatch_retry_reason: 'HTTP 429',
+        keep_me: 'preserved',
+      }),
+    }
+    const select = { get: vi.fn(() => failedTask) }
+    const update = { run: vi.fn() }
+    prepare.mockImplementation((sql: string) => sql.includes('SELECT * FROM tasks') ? select : update)
+
+    const { POST } = await import('@/app/api/tasks/[id]/retry/route')
+    const response = await POST(
+      new NextRequest('http://localhost/api/tasks/42/retry', { method: 'POST' }),
+      { params: Promise.resolve({ id: '42' }) },
+    )
+    const body = await response.json()
+
+    expect(response.status).toBe(200)
+    expect(body.success).toBe(true)
+    const metadata = JSON.parse(update.run.mock.calls[0][0])
+    expect(metadata.runtime_cancel_requested).toBeUndefined()
+    expect(metadata.runtime_cancelled_at).toBeUndefined()
+    expect(metadata.dispatch_retry_reason).toBeUndefined()
+    expect(metadata.keep_me).toBe('preserved')
+    expect(broadcast).toHaveBeenCalledWith('task.status_changed', expect.objectContaining({
+      id: 42,
+      status: 'assigned',
+      reason: 'manual_retry',
+    }))
+  })
+
+  it('rejects retrying a task that is not failed', async () => {
+    prepare.mockReturnValue({ get: vi.fn(() => ({
+      id: 43,
+      title: 'Active',
+      status: 'assigned',
+      assigned_to: 'Codex',
+      metadata: '{}',
+    })) })
+
+    const { POST } = await import('@/app/api/tasks/[id]/retry/route')
+    const response = await POST(
+      new NextRequest('http://localhost/api/tasks/43/retry', { method: 'POST' }),
+      { params: Promise.resolve({ id: '43' }) },
+    )
+
+    expect(response.status).toBe(409)
+  })
+})
