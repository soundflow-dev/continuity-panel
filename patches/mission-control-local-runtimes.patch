+function resolveTaskWorkingDirectory(task: DispatchableTask): string | undefined {
+  const root = (process.env.MC_WORKSPACE_ROOT || '').trim()
+  if (!root) return undefined
+
+  const path = require('node:path')
+  const resolvedRoot = path.resolve(root)
+  const candidates = [task.project_name, task.project_slug]
+    .filter((value): value is string => typeof value === 'string' && value.trim().length > 0)
+
+  for (const candidate of candidates) {
+    const resolved = path.resolve(resolvedRoot, candidate)
+    if (resolved !== resolvedRoot && resolved.startsWith(`${resolvedRoot}${path.sep}`) && existsSync(resolved)) {
+      return resolved
+    }
+  }
+  return existsSync(resolvedRoot) ? resolvedRoot : undefined
+}
