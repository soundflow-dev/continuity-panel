+function positiveEnvMilliseconds(name: string, fallback: number): number {
+  const parsed = Number.parseInt((process.env[name] || '').trim(), 10)
+  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback
+}
+
+/** Identify the short terminal error emitted by Hermes as a failed response. */
+export function getHermesTerminalError(text: string, stderr = '', exitCode = 0): string | null {
+  const output = text.trim()
+  const errorOutput = stderr.trim()
+  if (exitCode !== 0) {
+    return `Hermes CLI exited ${exitCode}: ${(errorOutput || output || 'no diagnostic output').slice(0, 2000)}`
+  }
+  if (/^API call failed after \d+ retr(?:y|ies):\s*(?:HTTP\s*)?(?:429|5\d\d)\b/i.test(output)) {
+    return output.slice(0, 2000)
+  }
+  if (/^(?:Hermes\s+)?(?:API|provider) error:\s*(?:HTTP\s*)?(?:429|5\d\d)\b/i.test(output)) {
+    return output.slice(0, 2000)
+  }
+  return null
+}
+
+/** Exponential retry delay, with a longer floor for provider rate limits. */
+export function getDispatchRetryDelaySeconds(error: string, attempt: number): number {
+  const rateLimited = /(?:HTTP\s*)?429\b|too many requests|rate[ -]?limit/i.test(error)
+  const base = rateLimited ? 60 : 30
+  return Math.min(base * (2 ** Math.max(0, attempt - 1)), rateLimited ? 900 : 600)
+}
