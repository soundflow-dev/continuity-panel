+describe('Hermes runtime resilience', () => {
+  it('treats a rate-limit response printed by Hermes as a terminal error', () => {
+    expect(getHermesTerminalError('API call failed after 3 retries: HTTP 429: Too Many Requests'))
+      .toContain('HTTP 429')
+  })
+
+  it('does not mistake a normal report that mentions HTTP 429 for a failed run', () => {
+    expect(getHermesTerminalError('I added handling for HTTP 429 responses and tests.')).toBeNull()
+  })
+
+  it('rejects non-zero exits even when Hermes wrote stdout', () => {
+    expect(getHermesTerminalError('partial response', 'provider crashed', 1))
+      .toContain('provider crashed')
+  })
+
+  it('backs off rate limits more aggressively and caps delays', () => {
+    expect(getDispatchRetryDelaySeconds('HTTP 429 Too Many Requests', 1)).toBe(60)
+    expect(getDispatchRetryDelaySeconds('HTTP 429 Too Many Requests', 4)).toBe(480)
+    expect(getDispatchRetryDelaySeconds('HTTP 429 Too Many Requests', 8)).toBe(900)
+    expect(getDispatchRetryDelaySeconds('temporary network error', 1)).toBe(30)
+  })
+})
