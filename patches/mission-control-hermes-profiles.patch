+function resolveHermesProfile(task: DispatchableTask): { id: string; home: string } | null {
+  if (!task.agent_config) return null
+  try {
+    const cfg = JSON.parse(task.agent_config)
+    const profile = typeof cfg.hermesProfile === 'string' ? cfg.hermesProfile.trim() : ''
+    if (!/^[a-z0-9][a-z0-9_-]*$/.test(profile)) return null
+
+    const path = require('node:path')
+    const rootValue = (process.env.HERMES_HOME || '').trim()
+    if (!rootValue) return null
+    const root = path.resolve(rootValue)
+    const home = path.resolve(root, 'profiles', profile)
+    if (!home.startsWith(`${root}${path.sep}`)) return null
+    if (!existsSync(path.join(home, 'config.yaml'))) {
+      throw new Error(`Hermes profile is not configured: ${profile}`)
+    }
+    return { id: profile, home }
+  } catch (error) {
+    if (error instanceof Error && error.message.startsWith('Hermes profile is not configured:')) {
+      throw error
+    }
+    return null
+  }
+}
