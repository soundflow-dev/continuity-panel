--- /dev/null
+++ b/src/lib/__tests__/task-selection.test.ts
@@ -0,0 +1,23 @@
+import { describe, expect, it } from 'vitest'
+import { getMissingTaskStateUpdate } from '@/lib/task-selection'
+
+describe('getMissingTaskStateUpdate', () => {
+  it('ignores a deliberately deleted task while the URL is catching up', () => {
+    expect(getMissingTaskStateUpdate(42, 42, false, null, false)).toBeNull()
+  })
+
+  it('writes the missing-task state only once', () => {
+    expect(getMissingTaskStateUpdate(42, null, false, null, true)).toEqual({
+      error: 'Task #42 not found in current workspace',
+      clearSelection: true,
+    })
+
+    expect(getMissingTaskStateUpdate(
+      42,
+      null,
+      false,
+      'Task #42 not found in current workspace',
+      false
+    )).toBeNull()
+  })
+})
diff --git a/src/lib/task-selection.ts b/src/lib/task-selection.ts
new file mode 100644
index 0000000..bf0984b
--- /dev/null
+++ b/src/lib/task-selection.ts
@@ -0,0 +1,24 @@
+export interface MissingTaskStateUpdate {
+  error: string | null
+  clearSelection: boolean
+}
+
+/**
+ * Calculates only the state writes needed when a taskId in the URL no longer
+ * exists. Returning null means the render must not write state at all.
+ */
+export function getMissingTaskStateUpdate(
+  taskId: number,
+  dismissedTaskId: number | null,
+  loading: boolean,
+  currentError: string | null,
+  hasSelectedTask: boolean
+): MissingTaskStateUpdate | null {
+  if (loading || dismissedTaskId === taskId) return null
+
+  const missingTaskError = `Task #${taskId} not found in current workspace`
+  const error = currentError === missingTaskError ? null : missingTaskError
+
+  if (error === null && !hasSelectedTask) return null
+  return { error, clearSelection: hasSelectedTask }
+}
