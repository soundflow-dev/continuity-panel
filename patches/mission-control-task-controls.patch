+++ b/src/lib/__tests__/task-cancel-route.test.ts
@@ -0,0 +1,83 @@
+import { beforeEach, describe, expect, it, vi } from 'vitest'
+import { NextRequest } from 'next/server'
+
+const requireRole = vi.fn()
+const prepare = vi.fn()
+const cancelActiveTaskExecution = vi.fn()
+const broadcast = vi.fn()
+const logActivity = vi.fn()
+
+vi.mock('@/lib/auth', () => ({ requireRole }))
+vi.mock('@/lib/rate-limit', () => ({ mutationLimiter: vi.fn(() => null) }))
+vi.mock('@/lib/enforcement/workspace-scope', () => ({
+  requireWorkspaceId: vi.fn((user) => ({ workspaceId: user.workspace_id })),
+  requireAgentTaskAccess: vi.fn(() => null),
+}))
+vi.mock('@/lib/task-dispatch', () => ({ cancelActiveTaskExecution }))
+vi.mock('@/lib/event-bus', () => ({ eventBus: { broadcast } }))
+vi.mock('@/lib/logger', () => ({ logger: { error: vi.fn() } }))
+vi.mock('@/lib/db', () => ({
+  getDatabase: vi.fn(() => ({ prepare })),
+  db_helpers: { logActivity },
+}))
+
+describe('POST /api/tasks/[id]/cancel', () => {
+  beforeEach(() => {
+    vi.resetModules()
+    vi.clearAllMocks()
+    requireRole.mockReturnValue({ user: { username: 'admin', role: 'admin', workspace_id: 1 } })
+    cancelActiveTaskExecution.mockReturnValue({ stopped: true, runtime: 'hermes' })
+  })
+
+  it('marks an active task as abandoned before stopping its process', async () => {
+    const task = {
+      id: 42,
+      title: 'Long Hermes job',
+      status: 'in_progress',
+      assigned_to: 'Hermes GLM',
+      metadata: JSON.stringify({ dispatch_not_before: 123 }),
+    }
+    const select = { get: vi.fn(() => task) }
+    const update = { run: vi.fn() }
+    prepare.mockImplementation((sql: string) => sql.includes('SELECT * FROM tasks') ? select : update)
+
+    const { POST } = await import('@/app/api/tasks/[id]/cancel/route')
+    const response = await POST(
+      new NextRequest('http://localhost/api/tasks/42/cancel', { method: 'POST' }),
+      { params: Promise.resolve({ id: '42' }) },
+    )
+    const body = await response.json()
+
+    expect(response.status).toBe(200)
+    expect(body).toEqual({ success: true, process_stopped: true, runtime: 'hermes' })
+    expect(update.run).toHaveBeenCalled()
+    const metadata = JSON.parse(update.run.mock.calls[0][1])
+    expect(metadata.runtime_cancel_requested).toBe(true)
+    expect(metadata.dispatch_not_before).toBeUndefined()
+    expect(cancelActiveTaskExecution).toHaveBeenCalledWith(42)
+    expect(broadcast).toHaveBeenCalledWith('task.status_changed', expect.objectContaining({
+      id: 42,
+      status: 'failed',
+      reason: 'user_cancelled',
+    }))
+  })
+
+  it('does not stop a task that has already finished', async () => {
+    prepare.mockReturnValue({ get: vi.fn(() => ({
+      id: 43,
+      title: 'Finished',
+      status: 'done',
+      assigned_to: 'Codex',
+      metadata: '{}',
+    })) })
+
+    const { POST } = await import('@/app/api/tasks/[id]/cancel/route')
+    const response = await POST(
+      new NextRequest('http://localhost/api/tasks/43/cancel', { method: 'POST' }),
+      { params: Promise.resolve({ id: '43' }) },
+    )
+
+    expect(response.status).toBe(409)
+    expect(cancelActiveTaskExecution).not.toHaveBeenCalled()
+  })
+})
