index 0000000..65390a5
--- /dev/null
+++ b/src/app/api/tasks/[id]/cancel/route.ts
@@ -0,0 +1,89 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { getDatabase, db_helpers, type Task } from '@/lib/db'
+import { requireRole } from '@/lib/auth'
+import { mutationLimiter } from '@/lib/rate-limit'
+import { requireAgentTaskAccess, requireWorkspaceId } from '@/lib/enforcement/workspace-scope'
+import { cancelActiveTaskExecution } from '@/lib/task-dispatch'
+import { eventBus } from '@/lib/event-bus'
+import { logger } from '@/lib/logger'
+
+const STOPPABLE_STATUSES = new Set(['assigned', 'in_progress', 'review', 'quality_review'])
+
+/** POST /api/tasks/[id]/cancel - stop local execution and prevent retries. */
+export async function POST(
+  request: NextRequest,
+  { params }: { params: Promise<{ id: string }> },
+) {
+  const auth = requireRole(request, 'operator')
+  if ('error' in auth) return NextResponse.json({ error: auth.error }, { status: auth.status })
+
+  const rateCheck = mutationLimiter(request)
+  if (rateCheck) return rateCheck
+
+  try {
+    const taskId = Number.parseInt((await params).id, 10)
+    if (!Number.isFinite(taskId)) return NextResponse.json({ error: 'Invalid task ID' }, { status: 400 })
+
+    const wsResult = requireWorkspaceId(auth.user)
+    if (!('workspaceId' in wsResult)) return wsResult.response
+    const { workspaceId } = wsResult
+    const db = getDatabase()
+    const task = db.prepare('SELECT * FROM tasks WHERE id = ? AND workspace_id = ?')
+      .get(taskId, workspaceId) as Task | undefined
+    if (!task) return NextResponse.json({ error: 'Task not found' }, { status: 404 })
+
+    const taskDeny = requireAgentTaskAccess(auth.user, task.assigned_to ?? null)
+    if (taskDeny) return taskDeny
+    if (!STOPPABLE_STATUSES.has(task.status)) {
+      return NextResponse.json({ error: `Task cannot be stopped while it is ${task.status}` }, { status: 409 })
+    }
+
+    const metadata = (() => {
+      try { return task.metadata ? JSON.parse(task.metadata) : {} } catch { return {} }
+    })()
+    const now = Math.floor(Date.now() / 1000)
+    metadata.runtime_cancel_requested = true
+    metadata.runtime_cancelled_at = now
+    metadata.runtime_cancelled_by = auth.user.username
+    delete metadata.dispatch_not_before
+    delete metadata.review_not_before
+
+    // Mark cancellation before signalling the child. Its close handler can then
+    // see the marker and will not put the task back into the retry queue.
+    db.prepare(`
+      UPDATE tasks
+      SET status = 'failed', outcome = 'abandoned', error_message = ?, metadata = ?, updated_at = ?
+      WHERE id = ? AND workspace_id = ?
+    `).run('Stopped by user', JSON.stringify(metadata), now, taskId, workspaceId)
+
+    const runtime = cancelActiveTaskExecution(taskId)
+    db_helpers.logActivity(
+      'task_cancelled',
+      'task',
+      taskId,
+      auth.user.username,
+      `Stopped task: ${task.title}`,
+      { previous_status: task.status, process_stopped: runtime.stopped, runtime: runtime.runtime },
+      workspaceId,
+    )
+    eventBus.broadcast('task.status_changed', {
+      id: taskId,
+      status: 'failed',
+      previous_status: task.status,
+      error_message: 'Stopped by user',
+      reason: 'user_cancelled',
+    })
+    eventBus.broadcast('task.updated', {
+      id: taskId,
+      status: 'failed',
+      outcome: 'abandoned',
+      error_message: 'Stopped by user',
+      metadata,
+    })
+
+    return NextResponse.json({ success: true, process_stopped: runtime.stopped, runtime: runtime.runtime })
+  } catch (error) {
+    logger.error({ err: error }, 'POST /api/tasks/[id]/cancel error')
+    return NextResponse.json({ error: 'Failed to stop task' }, { status: 500 })
+  }
+}
