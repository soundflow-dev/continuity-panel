 const AGENT_DISPATCH_ACCEPT_TIMEOUT_MS = 60_000
 
+type ActiveTaskProcess = {
+  proc: ReturnType<typeof spawn>
+  runtime: 'codex' | 'hermes'
+}
+
+const activeTaskProcesses = (() => {
+  const shared = globalThis as typeof globalThis & { __mcActiveTaskProcesses?: Map<number, ActiveTaskProcess> }
+  if (!shared.__mcActiveTaskProcesses) shared.__mcActiveTaskProcesses = new Map()
+  return shared.__mcActiveTaskProcesses
+})()
+
+function registerActiveTaskProcess(taskId: number, active: ActiveTaskProcess): void {
+  activeTaskProcesses.set(taskId, active)
+}
+
+function unregisterActiveTaskProcess(taskId: number, proc: ReturnType<typeof spawn>): void {
+  if (activeTaskProcesses.get(taskId)?.proc === proc) activeTaskProcesses.delete(taskId)
+}
+
+/** Stop a local Codex/Hermes child process that is currently executing a task. */
+export function cancelActiveTaskExecution(taskId: number): { stopped: boolean; runtime: string | null } {
+  const active = activeTaskProcesses.get(taskId)
+  if (!active) return { stopped: false, runtime: null }
+  active.proc.kill('SIGTERM')
+  setTimeout(() => {
+    if (active.proc.exitCode === null) active.proc.kill('SIGKILL')
+  }, 5000).unref()
+  return { stopped: true, runtime: active.runtime }
+}
